# Feishu App Credentials (required)
# Create at: https://open.feishu.cn/app
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Anthropic API Key (required)
# Used by both Vercel AI SDK and Claude Agent SDK
ANTHROPIC_API_KEY=

# Linear API Key (optional)
# Get from: https://linear.app/settings/api
# Required for requirement management features
LINEAR_API_KEY=

# Project root path (optional, defaults to current working directory)
# The bot reads code from this directory (read-only)
PROJECT_ROOT=
